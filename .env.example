# ── Required ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mengu?sslmode=disable
JWT_SECRET=dev-secret-change-in-production

# ── LLM ──
# Without this, the worker can't analyze emails — events will be marked "failed".
# Get a free key from: https://platform.deepseek.com/api_keys
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=30s

# ── Google OAuth (required for login via Google + Gmail/Calendar integration) ──
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth client ID
# 2. Set redirect URI to: http://localhost:8080/api/v1/auth/oauth/callback
# 3. Also enable Gmail API and Calendar API in your GCP project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/callback
FRONTEND_URL=http://localhost:5173

# ── Gmail push (production only — set this when you deploy) ──
# Create a Pub/Sub topic, add gmail-api-push@system.gserviceaccount.com as publisher
GMAIL_TOPIC_NAME=

# ── Optional defaults ──
PORT=8080
CORS_ALLOWED_ORIGINS=*
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=168h
WORKER_POLL_INTERVAL=5s
LOG_LEVEL=info
LOG_FORMAT=json
